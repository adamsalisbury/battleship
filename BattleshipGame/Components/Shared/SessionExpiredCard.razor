@* Shown when a game session cannot be found, has expired, or is otherwise inaccessible.
   Shared across Placement, Battle, and Lobby pages. Inherits render mode from the host page. *@

<div class="expired-screen">
    <div class="session-expired-card">

        <div class="expired-anchor-icon" aria-hidden="true">
            <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" width="60" height="60">
                <!-- Ring at top -->
                <circle cx="40" cy="16" r="9" fill="none" stroke="currentColor" stroke-width="4.5" />
                <!-- Vertical shaft -->
                <line x1="40" y1="25" x2="40" y2="66" stroke="currentColor" stroke-width="4.5" stroke-linecap="round" />
                <!-- Horizontal crossbar -->
                <line x1="22" y1="38" x2="58" y2="38" stroke="currentColor" stroke-width="4.5" stroke-linecap="round" />
                <!-- Curved arms (fluke) -->
                <path d="M22,66 Q40,54 58,66" fill="none" stroke="currentColor" stroke-width="4.5" stroke-linecap="round" />
                <!-- Left tip -->
                <line x1="22" y1="66" x2="16" y2="58" stroke="currentColor" stroke-width="4.5" stroke-linecap="round" />
                <!-- Right tip -->
                <line x1="58" y1="66" x2="64" y2="58" stroke="currentColor" stroke-width="4.5" stroke-linecap="round" />
            </svg>
        </div>

        <h2 class="expired-title">@Title</h2>
        <p class="expired-message">@Message</p>

        @if (Detail is not null)
        {
            <p class="expired-detail">@Detail</p>
        }

        <div class="expired-actions">
            <a href="/" class="btn btn-primary expired-cta">⊕ Start a New Game</a>
        </div>

    </div>
</div>

@code {
    /// <summary>Bold headline shown at the top of the card.</summary>
    [Parameter] public string Title { get; set; } = "Game Not Found";

    /// <summary>Main explanatory sentence shown below the title.</summary>
    [Parameter] public string Message { get; set; } =
        "This game session has expired or could not be found.";

    /// <summary>Optional secondary line with extra context (e.g., expiry duration).</summary>
    [Parameter] public string? Detail { get; set; } =
        "Sessions expire automatically after 2 hours of inactivity.";
}
