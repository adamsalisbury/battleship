@page "/placement/{Code}"
@rendermode InteractiveServer
@using BattleshipGame.Models
@using BattleshipGame.Services
@inject GameSessionService SessionService
@inject NavigationManager Nav
@inject PlayerCircuitTracker CircuitTracker
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Place Ships — Battleship</PageTitle>

@* Three mutually exclusive top-level states:
   1. Session not found / expired  → polished error card (full-screen centred)
   2. Session loading (transient)  → spinner
   3. Session ready                → full placement UI *@

@if (_error is not null)
{
    <SessionExpiredCard Title="Game Not Found"
                        Message=@($"Game session \"{Code}\" could not be found.")
                        Detail="Sessions expire automatically after 2 hours of inactivity. Ask your opponent to start a new game." />
}
else if (_session is null)
{
    <div class="lobby-loading">
        <div class="spinner"></div>
        <p>Loading game…</p>
    </div>
}
else
{
    <div class="placement-screen">

        @* Disconnect banner — shown when the opponent's connection has dropped *@
        @if (IsOpponentDisconnected)
        {
            <div class="disconnect-banner @(IsOpponentDisconnectExpired ? "disconnect-expired" : "")">
                @if (IsOpponentDisconnectExpired)
                {
                    <span class="disconnect-icon">⚠️</span>
                    <span class="disconnect-msg">@_opponentName has left the game.</span>
                    <a href="/" class="btn btn-ghost disconnect-home-btn">← Back to Home</a>
                }
                else
                {
                    <span class="disconnect-icon">📡</span>
                    <span class="disconnect-msg">@_opponentName has disconnected — waiting for them to reconnect…</span>
                }
            </div>
        }

        <!-- Header + status bar -->
        <div class="placement-header">
            <h2>Place Your Ships</h2>
            <div class="placement-status-panel">
                <div class="player-status @(_myReady ? "status-ready" : "status-waiting")">
                    <span class="status-name">@_playerName</span>
                    <span class="status-badge">@(_myReady ? "✓ Ready" : "Placing…")</span>
                </div>
                <div class="vs-small">VS</div>
                <div class="player-status @(_opponentReady ? "status-ready" : "status-waiting")">
                    <span class="status-name">@_opponentName</span>
                    <span class="status-badge">@(_opponentReady ? "✓ Ready" : "Placing…")</span>
                </div>
            </div>
        </div>

        <!-- Main two-column layout -->
        <div class="placement-layout">

            <!-- LEFT: placement grid -->
            <div class="placement-grid-area">
                <div class="placement-hint">
                    @if (_myReady)
                    {
                        <span class="hint-ready">⚓ Fleet deployed — waiting for @_opponentName…</span>
                    }
                    else if (_selectedShipType is not null)
                    {
                        <span>
                            Placing <strong>@_selectedShipType</strong> (@((int)_selectedShipType.Value) cells,
                            @(_isHorizontal ? "Horizontal" : "Vertical")) —
                            click or press Enter to place · press R to rotate · click ship again to cancel
                        </span>
                    }
                    else
                    {
                        <span>Select a ship from the panel, then click the grid to place it</span>
                    }
                </div>

                <div class="game-grid"
                     role="grid"
                     aria-label="Ship placement grid"
                     @onmouseleave="OnGridLeave">
                    <!-- Corner -->
                    <div class="grid-corner" role="presentation"></div>
                    <!-- Column labels -->
                    @foreach (var label in GridConstants.ColumnLabels)
                    {
                        <div class="grid-col-label" role="columnheader">@label</div>
                    }
                    <!-- Rows -->
                    @for (int row = 0; row < GridConstants.GridSize; row++)
                    {
                        var r = row;
                        <div class="grid-row-label" role="rowheader">@(row + 1)</div>
                        @for (int col = 0; col < GridConstants.GridSize; col++)
                        {
                            var c = col;
                            <div class="grid-cell @GetCellClass(r, c)"
                                 id="placement-cell-@r-@c"
                                 role="gridcell"
                                 aria-label="@GetPlacementCellAriaLabel(r, c)"
                                 tabindex="@GetPlacementCellTabIndex(r, c)"
                                 @onmouseenter="() => OnCellHover(r, c)"
                                 @onfocus="() => OnPlacementCellFocus(r, c)"
                                 @onclick="() => OnCellClick(r, c)"
                                 @onkeydown="e => OnPlacementCellKeyDown(e, r, c)">
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- RIGHT: fleet panel -->
            <div class="placement-fleet-panel">
                <div class="fleet-panel-header">Your Fleet</div>

                <div class="fleet-list">
                    @foreach (var (shipType, shipName) in GridConstants.Fleet)
                    {
                        var type = shipType;
                        var name = shipName;
                        bool isPlaced = _myBoard?.Ships.Any(s => s.Type == type) ?? false;
                        bool isSelected = _selectedShipType == type;
                        string itemClass = "fleet-item"
                            + (isSelected ? " fleet-item-selected" : "")
                            + (isPlaced && !isSelected ? " fleet-item-placed" : "")
                            + (_myReady ? " fleet-item-disabled" : "");
                        string itemLabel = isSelected ? $"{name} — currently placing"
                            : isPlaced ? $"{name} — placed"
                            : $"{name} — not placed. Press Enter to select.";

                        <div class="@itemClass"
                             role="button"
                             tabindex="@(_myReady ? "-1" : "0")"
                             aria-label="@itemLabel"
                             aria-pressed="@isSelected.ToString().ToLower()"
                             @onclick="() => SelectShip(type)"
                             @onkeydown="e => OnFleetItemKeyDown(e, type)">
                            <div class="fleet-item-left">
                                <span class="fleet-ship-name">@name</span>
                                <div class="fleet-ship-pips">
                                    @for (int i = 0; i < (int)type; i++)
                                    {
                                        <span class="fleet-pip @GetPipClass(isPlaced, isSelected, name)"></span>
                                    }
                                </div>
                            </div>
                            <div class="fleet-item-right">
                                @if (isPlaced && !isSelected)
                                {
                                    <span class="fleet-badge fleet-badge-placed">✓ Placed</span>
                                }
                                else if (isSelected)
                                {
                                    <span class="fleet-badge fleet-badge-selecting">▶ Placing</span>
                                }
                                else
                                {
                                    <span class="fleet-badge fleet-badge-pending">Not placed</span>
                                }
                            </div>
                        </div>
                    }
                </div>

                @if (!_myReady)
                {
                    <div class="fleet-controls">

                        <div class="orientation-row">
                            <span class="orientation-label">Orientation <kbd>R</kbd></span>
                            <div class="orientation-buttons">
                                <button class="btn-orient @(_isHorizontal ? "orient-active" : "")"
                                        aria-pressed="@_isHorizontal.ToString().ToLower()"
                                        @onclick='() => SetOrientation(true)'>
                                    ⟷ Horizontal
                                </button>
                                <button class="btn-orient @(!_isHorizontal ? "orient-active" : "")"
                                        aria-pressed="@(!_isHorizontal).ToString().ToLower()"
                                        @onclick='() => SetOrientation(false)'>
                                    ⟵ Vertical
                                </button>
                            </div>
                        </div>

                        <div class="action-row">
                            <button class="btn btn-secondary" @onclick="Randomise">⚄ Randomise</button>
                            <button class="btn btn-ghost" @onclick="ClearAll"
                                    disabled="@(!(_myBoard?.Ships.Count > 0))">
                                ✕ Clear
                            </button>
                        </div>

                        <button class="btn btn-primary btn-ready"
                                @onclick="MarkReady"
                                disabled="@(!AllShipsPlaced())">
                            @if (AllShipsPlaced())
                            {
                                <span>⚓ Ready for Battle!</span>
                            }
                            else
                            {
                                var remaining = GridConstants.Fleet.Length - (_myBoard?.Ships.Count ?? 0);
                                <span>Place @remaining more ship@(remaining == 1 ? "" : "s") to continue</span>
                            }
                        </button>

                    </div>
                }

                @if (_myReady)
                {
                    <div class="ready-waiting">
                        <div class="spinner"></div>
                        <p>Waiting for @_opponentName to finish placing…</p>
                    </div>
                }
            </div>

        </div>
    </div>
}

@code {
    [Parameter] public string Code { get; set; } = "";
    [SupplyParameterFromQuery] public string? Name { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }

    private GameSession? _session;
    private PlayerBoard? _myBoard;
    private string _playerName = "";
    private string _opponentName = "";
    private bool _myReady;
    private bool _opponentReady;
    private string? _error;
    private bool _navigated;

    // ── Disconnect state ───────────────────────────────────────────────────

    private bool IsOpponentDisconnected => _session?.IsOpponentDisconnected(_playerName) == true;
    private bool IsOpponentDisconnectExpired => _session?.IsDisconnectExpired(_opponentName) == true;

    // Placement interaction state
    private ShipType? _selectedShipType;
    private bool _isHorizontal = true;
    private int _hoverRow = -1;
    private int _hoverCol = -1;
    private HashSet<(int, int)>? _previewCells;
    private bool _previewValid;

    // ── Roving tabindex for the placement grid ─────────────────────────────
    private int _gridFocusRow = -1;
    private int _gridFocusCol = -1;

    // ── Lifecycle ──────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        _playerName = Name ?? "Player";
        _session = SessionService.GetSession(Code);

        if (_session is null)
        {
            _error = "Game session not found.";
            return;
        }

        // Register circuit → player mapping so disconnect events are detected
        CircuitTracker.SessionCode = Code;
        CircuitTracker.PlayerName = _playerName;
        CircuitTracker.Token = Token ?? "";

        // If this player was previously disconnected, mark them as reconnected
        var me = _session.GetPlayerByName(_playerName);
        if (me?.IsDisconnected == true)
            _session.MarkPlayerReconnected(_playerName, Token ?? "");

        RefreshState();
        _session.StateChanged += OnSessionStateChanged;
    }

    private async void OnSessionStateChanged()
    {
        await InvokeAsync(() =>
        {
            RefreshState();
            StateHasChanged();
        });

        if (!_navigated && _session?.Phase == GamePhase.Battle)
        {
            _navigated = true;
            await InvokeAsync(() =>
                Nav.NavigateTo($"/battle/{Code}?name={Uri.EscapeDataString(Name ?? "Player")}&token={Uri.EscapeDataString(Token ?? "")}"));
        }
    }

    private void RefreshState()
    {
        if (_session is null) return;
        var me = _session.GetPlayerByName(_playerName);
        var opponent = _playerName == _session.Host?.Name ? _session.Guest : _session.Host;
        _opponentName = opponent?.Name ?? "Opponent";
        _myReady = me?.Board.IsReady ?? false;
        _opponentReady = opponent?.Board.IsReady ?? false;
        _myBoard = _session.GetOwnBoard(_playerName);
    }

    // ── Grid Interaction ───────────────────────────────────────────────────

    private void OnCellHover(int row, int col)
    {
        if (_myReady || _selectedShipType is null) return;
        if (_hoverRow == row && _hoverCol == col) return;
        _hoverRow = row;
        _hoverCol = col;
        UpdatePreview();
    }

    private void OnGridLeave()
    {
        _hoverRow = -1;
        _hoverCol = -1;
        _previewCells = null;
    }

    private void OnCellClick(int row, int col)
    {
        if (_myReady || _selectedShipType is null) return;
        if (!_previewValid || _previewCells is null) return;

        // Remove existing ship of this type if it was already placed (re-placement)
        _session!.RemoveShip(_playerName, _selectedShipType.Value);

        var ship = new Ship
        {
            Type = _selectedShipType.Value,
            IsHorizontal = _isHorizontal,
            Row = row,
            Column = col
        };

        if (_session.PlaceShip(_playerName, ship))
        {
            _selectedShipType = null;
            _previewCells = null;
            _hoverRow = -1;
            _hoverCol = -1;
        }

        RefreshState();
    }

    private void UpdatePreview()
    {
        if (_selectedShipType is null || _hoverRow < 0)
        {
            _previewCells = null;
            return;
        }

        var size = (int)_selectedShipType.Value;
        var cells = new HashSet<(int, int)>();
        for (var i = 0; i < size; i++)
        {
            cells.Add(_isHorizontal
                ? (_hoverRow, _hoverCol + i)
                : (_hoverRow + i, _hoverCol));
        }
        _previewCells = cells;

        // Valid if all cells are in bounds and no overlap with OTHER ships
        var inBounds = cells.All(c =>
            c.Item1 >= 0 && c.Item1 < GridConstants.GridSize &&
            c.Item2 >= 0 && c.Item2 < GridConstants.GridSize);

        if (!inBounds)
        {
            _previewValid = false;
            return;
        }

        // Exclude the ship currently being re-placed from the overlap check
        var occupied = _myBoard?.Ships
            .Where(s => s.Type != _selectedShipType.Value)
            .SelectMany(s => s.Cells)
            .ToHashSet() ?? [];

        _previewValid = !cells.Overlaps(occupied);
    }

    // ── Keyboard Navigation — Placement Grid ───────────────────────────────

    /// <summary>
    /// When a grid cell gains focus (keyboard or mouse), update hover + roving tabindex.
    /// </summary>
    private void OnPlacementCellFocus(int row, int col)
    {
        _gridFocusRow = row;
        _gridFocusCol = col;
        OnCellHover(row, col);
    }

    /// <summary>
    /// Handles keyboard input on placement grid cells.
    /// Enter/Space places the ship; arrow keys navigate; R rotates orientation.
    /// </summary>
    private async Task OnPlacementCellKeyDown(KeyboardEventArgs e, int row, int col)
    {
        switch (e.Key)
        {
            case "Enter":
            case " ":
                OnCellClick(row, col);
                break;
            case "ArrowUp":
                await MovePlacementFocusTo(row - 1, col);
                break;
            case "ArrowDown":
                await MovePlacementFocusTo(row + 1, col);
                break;
            case "ArrowLeft":
                await MovePlacementFocusTo(row, col - 1);
                break;
            case "ArrowRight":
                await MovePlacementFocusTo(row, col + 1);
                break;
            case "r":
            case "R":
                SetOrientation(!_isHorizontal);
                break;
        }
    }

    /// <summary>Moves keyboard focus to the specified placement grid cell (clamped to bounds).</summary>
    private async Task MovePlacementFocusTo(int row, int col)
    {
        if (row < 0 || row >= GridConstants.GridSize) return;
        if (col < 0 || col >= GridConstants.GridSize) return;
        _gridFocusRow = row;
        _gridFocusCol = col;
        OnCellHover(row, col);
        await JS.InvokeVoidAsync("focusElement", $"placement-cell-{row}-{col}");
    }

    /// <summary>
    /// Roving tabindex for the placement grid.
    /// Cells are only navigable when a ship is selected and the player isn't ready.
    /// Exactly one cell has tabindex=0: the tracked focus cell or (0,0) as entry point.
    /// </summary>
    private string GetPlacementCellTabIndex(int row, int col)
    {
        if (_myReady || _selectedShipType is null) return "-1";

        if (_gridFocusRow >= 0 && _gridFocusCol >= 0)
            return (_gridFocusRow == row && _gridFocusCol == col) ? "0" : "-1";

        // Default entry point when no cell is focused yet
        return (row == 0 && col == 0) ? "0" : "-1";
    }

    /// <summary>Accessible label for a placement grid cell.</summary>
    private string GetPlacementCellAriaLabel(int row, int col)
    {
        var coord = $"{GridConstants.ColumnLabels[col]}{row + 1}";

        if (_previewCells is not null && _previewCells.Contains((row, col)))
        {
            var validity = _previewValid ? "valid placement" : "invalid placement";
            return $"{coord}, {_selectedShipType} preview — {validity}";
        }

        var ship = _myBoard?.Ships.FirstOrDefault(s => s.Cells.Contains((row, col)));
        if (ship is not null) return $"{coord}, {ship.Name} placed";

        return _selectedShipType is not null
            ? $"{coord}, empty — press Enter to place {_selectedShipType}"
            : $"{coord}, empty";
    }

    // ── Keyboard Navigation — Fleet Panel ──────────────────────────────────

    /// <summary>
    /// Handles keyboard input on fleet item buttons.
    /// Enter/Space selects or deselects the ship; R rotates orientation.
    /// </summary>
    private void OnFleetItemKeyDown(KeyboardEventArgs e, ShipType type)
    {
        switch (e.Key)
        {
            case "Enter":
            case " ":
                SelectShip(type);
                break;
            case "r":
            case "R":
                if (_selectedShipType is not null && !_myReady)
                    SetOrientation(!_isHorizontal);
                break;
        }
    }

    // ── Ship Selection ─────────────────────────────────────────────────────

    private void SelectShip(ShipType type)
    {
        if (_myReady) return;

        // Toggle: clicking the same ship again deselects it
        if (_selectedShipType == type)
        {
            _selectedShipType = null;
            _previewCells = null;
            return;
        }

        _selectedShipType = type;
        _previewCells = null;
        // Reset grid focus so the entry point defaults back to (0,0) for the new ship
        _gridFocusRow = -1;
        _gridFocusCol = -1;
        UpdatePreview();
    }

    private void SetOrientation(bool horizontal)
    {
        _isHorizontal = horizontal;
        UpdatePreview();
    }

    // ── Actions ────────────────────────────────────────────────────────────

    private void Randomise()
    {
        if (_myReady) return;
        _session!.ClearShips(_playerName);
        foreach (var ship in PlacementService.GenerateRandomPlacement())
            _session.PlaceShip(_playerName, ship);
        _selectedShipType = null;
        _previewCells = null;
        RefreshState();
    }

    private void ClearAll()
    {
        if (_myReady) return;
        _session!.ClearShips(_playerName);
        _selectedShipType = null;
        _previewCells = null;
        RefreshState();
    }

    private void MarkReady()
    {
        if (!AllShipsPlaced()) return;
        _session!.MarkPlayerReady(_playerName);
        _selectedShipType = null;
        _previewCells = null;
        RefreshState();
    }

    private bool AllShipsPlaced() => _myBoard?.HasFullFleet() ?? false;

    // ── Cell Display ───────────────────────────────────────────────────────

    private string GetCellClass(int row, int col)
    {
        // Preview overlay takes priority
        if (_previewCells is not null && _previewCells.Contains((row, col)))
            return _previewValid ? "cell-preview-valid" : "cell-preview-invalid";

        // Ship occupies this cell
        var ship = _myBoard?.Ships.FirstOrDefault(s => s.Cells.Contains((row, col)));
        if (ship is not null)
            return $"cell-ship cell-ship-{ship.Name.ToLower()}";

        return "cell-empty";
    }

    private static string GetPipClass(bool isPlaced, bool isSelected, string shipName) =>
        isSelected ? "pip-active"
        : isPlaced ? $"pip-{shipName.ToLower()}"
        : "pip-pending";

    // ── Dispose ────────────────────────────────────────────────────────────

    public void Dispose()
    {
        if (_session is not null)
            _session.StateChanged -= OnSessionStateChanged;
    }
}
