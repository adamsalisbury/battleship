@page "/battle/{Code}"
@rendermode InteractiveServer
@inject GameSessionService SessionService
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Battle — Battleship</PageTitle>

<div class="battle-screen">
    @if (_session is null)
    {
        <div class="lobby-loading">
            <div class="spinner"></div>
            <p>Loading battle…</p>
        </div>
    }
    else if (_error is not null)
    {
        <div class="lobby-error">
            <p class="error-msg">@_error</p>
            <a href="/" class="btn btn-ghost">← Back to Home</a>
        </div>
    }
    else
    {
        <!-- Turn indicator -->
        <div class="battle-header">
            <div class="turn-indicator @(IsMyTurn ? "my-turn" : "their-turn")">
                @if (_session.Phase == GamePhase.Finished)
                {
                    <span>⚓ Battle Over</span>
                }
                else if (IsMyTurn)
                {
                    <span>🎯 Your turn — pick a target, @_playerName</span>
                }
                else
                {
                    <span>⏳ @_opponentName is aiming…</span>
                }
            </div>
        </div>

        <!-- Shot history bar -->
        <div class="shot-history-bar @(RecentShots.Count == 0 ? "shot-history-empty" : "")">
            @if (RecentShots.Count == 0)
            {
                <span class="shot-history-placeholder">No shots fired yet</span>
            }
            else
            {
                <span class="shot-history-label">Recent shots:</span>
                <div class="shot-history-list">
                    @for (int si = 0; si < RecentShots.Count; si++)
                    {
                        var shot = RecentShots[si];
                        var isLatest = si == 0;
                        var coord = FormatCoord(shot.Row, shot.Col);
                        // Stable key: the shot's index in the full history (newest = highest index)
                        var shotKey = (_session?.ShotHistory.Count ?? 0) - 1 - si;
                        var chipClass = shot.Result switch
                        {
                            ShotResult.Miss => "shot-chip-miss",
                            ShotResult.Hit  => "shot-chip-hit",
                            ShotResult.Sunk => "shot-chip-sunk",
                            _               => ""
                        };
                        var icon = shot.Result switch
                        {
                            ShotResult.Miss => "💧",
                            ShotResult.Hit  => "🔥",
                            ShotResult.Sunk => "💥",
                            _               => ""
                        };
                        <div @key="shotKey" class="shot-chip @chipClass @(isLatest ? "shot-chip-latest" : "")">
                            <span class="shot-chip-icon">@icon</span>
                            <span class="shot-chip-coord">@coord</span>
                            @if (isLatest)
                            {
                                var resultText = shot.Result switch
                                {
                                    ShotResult.Sunk => $"sank {shot.SunkShipName}!",
                                    ShotResult.Hit  => "hit!",
                                    ShotResult.Miss => "miss.",
                                    _               => ""
                                };
                                <span class="shot-chip-detail">@shot.ShooterName — @resultText</span>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Shot result toast -->
        @if (_toastMessage is not null)
        {
            <div class="shot-toast @_toastClass" role="status" aria-live="polite">@_toastMessage</div>
        }

        <!-- Two battle grids -->
        <div class="battle-area">

            <!-- Own grid: shows your ships + where opponent has shot -->
            <div class="grid-section my-grid-section">
                <h3 class="grid-title">Your Waters — @_playerName</h3>
                <p class="grid-hint">Opponent fires here</p>
                <div class="game-grid battle-own-grid">
                    <div class="grid-corner"></div>
                    @foreach (var label in GridConstants.ColumnLabels)
                    {
                        <div class="grid-col-label">@label</div>
                    }
                    @for (int row = 0; row < GridConstants.GridSize; row++)
                    {
                        var r = row;
                        <div class="grid-row-label">@(row + 1)</div>
                        @for (int col = 0; col < GridConstants.GridSize; col++)
                        {
                            var c = col;
                            <div class="grid-cell @GetOwnCellClass(r, c)"></div>
                        }
                    }
                </div>

                <!-- Own fleet status -->
                <div class="fleet-status-panel">
                    <h4 class="fleet-status-title">Your Fleet</h4>
                    @foreach (var ship in GetOwnFleetOrdered())
                    {
                        var ownStatusClass = GetOwnShipStatusClass(ship);
                        var ownStatusLabel = GetOwnShipStatusLabel(ship);
                        var ownShipNameLower = ship.Name.ToLower();
                        <div class="fleet-status-row @ownStatusClass">
                            <span class="fleet-status-color-dot color-dot-@ownShipNameLower"></span>
                            <span class="fleet-status-name">@ship.Name</span>
                            <span class="fleet-status-pips">
                                @for (int i = 0; i < ship.Size; i++)
                                {
                                    <span class="fleet-pip @(i < ship.HitCount ? "pip-hit" : $"pip-{ownShipNameLower}")"></span>
                                }
                            </span>
                            <span class="fleet-status-badge badge-@ownStatusLabel.ToLower()">@ownStatusLabel</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Divider -->
            <div class="battle-divider">
                <span class="battle-vs">⚓</span>
            </div>

            <!-- Enemy grid: shows shots taken at opponent, click to fire -->
            <div class="grid-section enemy-grid-section">
                <h3 class="grid-title">Enemy Waters — @_opponentName</h3>
                <p class="grid-hint">
                    @if (_session.Phase == GamePhase.Finished)
                    {
                        <span>Battle concluded</span>
                    }
                    else if (IsMyTurn)
                    {
                        <span>Click to fire</span>
                    }
                    else
                    {
                        <span>Waiting for opponent's shot…</span>
                    }
                </p>
                <div class="game-grid battle-enemy-grid">
                    <div class="grid-corner"></div>
                    @foreach (var label in GridConstants.ColumnLabels)
                    {
                        <div class="grid-col-label">@label</div>
                    }
                    @for (int row = 0; row < GridConstants.GridSize; row++)
                    {
                        var r = row;
                        <div class="grid-row-label">@(row + 1)</div>
                        @for (int col = 0; col < GridConstants.GridSize; col++)
                        {
                            var c = col;
                            <div class="grid-cell @GetEnemyCellClass(r, c)"
                                 @onclick="() => OnEnemyCellClick(r, c)"></div>
                        }
                    }
                </div>

                <!-- Enemy fleet status -->
                <div class="fleet-status-panel">
                    <h4 class="fleet-status-title">Enemy Fleet</h4>
                    @foreach (var fleetEntry in GridConstants.Fleet)
                    {
                        var enemyShipType = fleetEntry.Type;
                        var enemyShipName = fleetEntry.Name;
                        var enemyShipSize = (int)fleetEntry.Type;
                        var enemyIsSunk = IsEnemyShipSunk(enemyShipType);
                        var enemyStatusLabel = enemyIsSunk ? "Sunk" : "Active";
                        var enemyStatusClass = enemyIsSunk ? "fleet-status-sunk" : "fleet-status-active";
                        var enemyShipNameLower = enemyShipName.ToLower();
                        <div class="fleet-status-row @enemyStatusClass">
                            <span class="fleet-status-color-dot color-dot-@enemyShipNameLower"></span>
                            <span class="fleet-status-name">@enemyShipName</span>
                            <span class="fleet-status-pips">
                                @for (int i = 0; i < enemyShipSize; i++)
                                {
                                    <span class="fleet-pip @(enemyIsSunk ? "pip-sunk" : $"pip-{enemyShipNameLower}")"></span>
                                }
                            </span>
                            <span class="fleet-status-badge badge-@enemyStatusLabel.ToLower()">@enemyStatusLabel</span>
                        </div>
                    }
                </div>
            </div>

        </div>

        <!-- Game over overlay -->
        @if (_session.Phase == GamePhase.Finished)
        {
            <div class="result-overlay">
                <div class="result-card result-card-wide">

                    <!-- Banner -->
                    <div class="result-banner">
                        <p class="result-subtitle-small">⚓ Battle Over</p>
                        @if (IsWinner)
                        {
                            <h2 class="result-win">🏆 Victory! You sank the fleet!</h2>
                            <p class="result-desc">Commander @_playerName, you have won the Battle of the Seas.</p>
                        }
                        else
                        {
                            <h2 class="result-loss">💀 Defeat — Fleet Destroyed</h2>
                            <p class="result-desc">@_opponentName has sunk your entire fleet.</p>
                        }
                    </div>

                    <!-- Stats grid: winner on left, loser on right -->
                    <div class="result-stats-grid">

                        <div class="result-stat-col stat-col-winner">
                            <div class="result-stat-header">
                                <span class="result-player-icon">🏆</span>
                                <span class="result-player-name">@WinnerName</span>
                                <span class="result-role-badge badge-winner">WINNER</span>
                            </div>
                            <div class="result-stat-row">
                                <span class="result-stat-label">Shots fired</span>
                                <span class="result-stat-value">@GetShotCount(WinnerName)</span>
                            </div>
                            <div class="result-stat-row">
                                <span class="result-stat-label">Hits</span>
                                <span class="result-stat-value">@GetHitCount(WinnerName)</span>
                            </div>
                            <div class="result-stat-row">
                                <span class="result-stat-label">Accuracy</span>
                                <span class="result-stat-value">@GetAccuracy(WinnerName)</span>
                            </div>
                            <div class="result-stat-row">
                                <span class="result-stat-label">Ships sunk</span>
                                <span class="result-stat-value">@GetShipsSunkCount(WinnerName)<span class="result-stat-total">/5</span></span>
                            </div>
                        </div>

                        <div class="result-vs-divider">VS</div>

                        <div class="result-stat-col stat-col-loser">
                            <div class="result-stat-header">
                                <span class="result-player-icon">💀</span>
                                <span class="result-player-name">@LoserName</span>
                                <span class="result-role-badge badge-loser">DEFEATED</span>
                            </div>
                            <div class="result-stat-row">
                                <span class="result-stat-label">Shots fired</span>
                                <span class="result-stat-value">@GetShotCount(LoserName)</span>
                            </div>
                            <div class="result-stat-row">
                                <span class="result-stat-label">Hits</span>
                                <span class="result-stat-value">@GetHitCount(LoserName)</span>
                            </div>
                            <div class="result-stat-row">
                                <span class="result-stat-label">Accuracy</span>
                                <span class="result-stat-value">@GetAccuracy(LoserName)</span>
                            </div>
                            <div class="result-stat-row">
                                <span class="result-stat-label">Ships sunk</span>
                                <span class="result-stat-value">@GetShipsSunkCount(LoserName)<span class="result-stat-total">/5</span></span>
                            </div>
                        </div>

                    </div>

                    <!-- Rematch voting -->
                    <div class="result-actions">
                        <button class="btn @(HasVotedRematch ? "btn-voted" : "btn-success")"
                                @onclick="OnPlayAgain"
                                disabled="@HasVotedRematch">
                            @if (HasVotedRematch)
                            {
                                <span>✓ Rematch vote cast</span>
                            }
                            else
                            {
                                <span>🔄 Play Again</span>
                            }
                        </button>
                        <a href="/" class="btn btn-ghost">← Back to Home</a>
                    </div>

                    <div class="result-vote-status">
                        @if (_session.RematchVoteCount == 0)
                        {
                            <span>Click "Play Again" to propose a rematch.</span>
                        }
                        else if (_session.RematchVoteCount == 1 && HasVotedRematch)
                        {
                            <span>⏳ Waiting for @_opponentName to accept…</span>
                        }
                        else if (_session.RematchVoteCount == 1 && !HasVotedRematch)
                        {
                            <span>⚡ @_opponentName wants a rematch — accept above!</span>
                        }
                    </div>

                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public string Code { get; set; } = "";
    [SupplyParameterFromQuery] public string? Name { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }

    private GameSession? _session;
    private string _playerName = "";
    private string _opponentName = "";
    private string? _error;

    // Toast notification state
    private string? _toastMessage;
    private string _toastClass = "";
    private System.Threading.Timer? _toastTimer;

    private bool IsMyTurn => _session?.ActivePlayer?.Name == _playerName;

    // ─── Result screen properties ─────────────────────────────────────────────
    private bool IsWinner => _session?.Winner?.Name == _playerName;
    private string WinnerName => _session?.Winner?.Name ?? "";
    private string LoserName => _session?.Loser?.Name ?? "";
    private bool HasVotedRematch => _session?.HasVotedRematch(_playerName) ?? false;

    // ─── Lifecycle ────────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        _playerName = Name ?? "Player";
        _session = SessionService.GetSession(Code);

        if (_session is null)
        {
            _error = "Game session not found.";
            return;
        }

        if (_session.Phase is not GamePhase.Battle and not GamePhase.Finished)
        {
            _error = "This game is not in the Battle phase.";
            return;
        }

        var opponent = _playerName == _session.Host?.Name ? _session.Guest : _session.Host;
        _opponentName = opponent?.Name ?? "Opponent";

        _session.StateChanged += OnSessionStateChanged;
    }

    private async void OnSessionStateChanged()
    {
        // Both players accepted a rematch — navigate to placement phase
        if (_session?.Phase == GamePhase.Placement)
        {
            var name = Uri.EscapeDataString(Name ?? "");
            var token = Uri.EscapeDataString(Token ?? "");
            await InvokeAsync(() => Nav.NavigateTo($"/placement/{Code}?name={name}&token={token}"));
            return;
        }
        await InvokeAsync(StateHasChanged);
    }

    // ─── Shot firing ──────────────────────────────────────────────────────────

    private void OnEnemyCellClick(int row, int col)
    {
        if (!IsMyTurn || _session is null) return;
        if (_session.Phase != GamePhase.Battle) return;

        var enemyBoard = _session.GetOpponentBoard(_playerName);
        if (enemyBoard is null) return;
        if (enemyBoard.ShotGrid[row, col] != CellState.Unknown) return;

        var result = _session.FireShot(_playerName, row, col);
        if (result is null) return;

        var sunkShipName = result == ShotResult.Sunk ? _session.LastShot?.SunkShipName : null;
        ShowToast(result.Value, sunkShipName);
    }

    /// <summary>Displays a shot result toast that auto-dismisses after 3.5 seconds.</summary>
    private void ShowToast(ShotResult result, string? sunkShipName)
    {
        _toastTimer?.Dispose();

        (_toastMessage, _toastClass) = result switch
        {
            ShotResult.Miss => ("💧 Miss!", "toast-miss"),
            ShotResult.Hit  => ("🔥 Hit!", "toast-hit"),
            ShotResult.Sunk => ($"💥 {sunkShipName} sunk!", "toast-sunk"),
            _               => ("", "")
        };

        // Schedule auto-dismiss
        _toastTimer = new System.Threading.Timer(async _ =>
        {
            _toastTimer?.Dispose();
            _toastTimer = null;
            await InvokeAsync(() =>
            {
                _toastMessage = null;
                StateHasChanged();
            });
        }, null, 3500, System.Threading.Timeout.Infinite);
    }

    // ─── Shot history helpers ─────────────────────────────────────────────────

    /// <summary>The 5 most recent shots, newest first, for the shot history bar.</summary>
    private List<ShotRecord> RecentShots =>
        _session?.ShotHistory.AsEnumerable().Reverse().Take(5).ToList() ?? [];

    /// <summary>Formats a grid coordinate as a human-readable string, e.g. "B7".</summary>
    private static string FormatCoord(int row, int col) =>
        $"{GridConstants.ColumnLabels[col]}{row + 1}";

    // ─── Cell class helpers ───────────────────────────────────────────────────

    /// <summary>CSS class for a cell on the player's own grid (shows ships + where opponent shot).</summary>
    private string GetOwnCellClass(int row, int col)
    {
        var ownBoard = _session!.GetOwnBoard(_playerName)!;
        var shotState = ownBoard.ShotGrid[row, col];

        if (shotState == CellState.Miss)
            return "cell-own-miss";

        if (shotState == CellState.Hit)
        {
            var hitShip = ownBoard.Ships.FirstOrDefault(s => s.Cells.Contains((row, col)));
            return hitShip?.IsSunk == true ? "cell-own-sunk" : "cell-own-hit";
        }

        // Cell has not been shot — show ship if present
        var ship = ownBoard.Ships.FirstOrDefault(s => s.Cells.Contains((row, col)));
        return ship is not null
            ? $"cell-ship cell-ship-{ship.Name.ToLower()}"
            : "cell-own-empty";
    }

    /// <summary>CSS class for a cell on the enemy grid (tracks shots taken at opponent).</summary>
    private string GetEnemyCellClass(int row, int col)
    {
        var enemyBoard = _session!.GetOpponentBoard(_playerName)!;
        var shotState = enemyBoard.ShotGrid[row, col];

        if (shotState == CellState.Miss)
            return "cell-enemy-miss";

        if (shotState == CellState.Hit)
        {
            // Reveal sunk ships on the enemy grid
            var ship = enemyBoard.Ships.FirstOrDefault(s => s.Cells.Contains((row, col)));
            if (ship?.IsSunk == true)
                return $"cell-enemy-sunk cell-ship-{ship.Name.ToLower()}";
            return "cell-enemy-hit";
        }

        // Unknown cell — targetable when it's my turn
        return IsMyTurn && _session.Phase == GamePhase.Battle
            ? "cell-enemy-unknown cell-enemy-targetable"
            : "cell-enemy-unknown";
    }

    // ─── Fleet status helpers ─────────────────────────────────────────────────

    /// <summary>Returns own ships in fleet definition order (Carrier → Destroyer).</summary>
    private IEnumerable<Ship> GetOwnFleetOrdered()
    {
        var board = _session?.GetOwnBoard(_playerName);
        if (board is null) return [];
        return GridConstants.Fleet
            .Select(f => board.Ships.FirstOrDefault(s => s.Type == f.Type))
            .OfType<Ship>();
    }

    /// <summary>CSS modifier class reflecting own ship's damage state.</summary>
    private static string GetOwnShipStatusClass(Ship ship) => ship switch
    {
        { IsSunk: true }    => "fleet-status-sunk",
        { HitCount: > 0 }  => "fleet-status-damaged",
        _                   => "fleet-status-afloat"
    };

    /// <summary>Display label for own ship's damage state.</summary>
    private static string GetOwnShipStatusLabel(Ship ship) => ship switch
    {
        { IsSunk: true }   => "Sunk",
        { HitCount: > 0 }  => "Damaged",
        _                  => "Afloat"
    };

    /// <summary>Returns true if the enemy ship of this type has been sunk.</summary>
    private bool IsEnemyShipSunk(ShipType type)
    {
        if (_session is null) return false;
        var board = _session.GetOpponentBoard(_playerName);
        return board?.Ships.FirstOrDefault(s => s.Type == type)?.IsSunk == true;
    }

    // ─── Rematch ──────────────────────────────────────────────────────────────

    private void OnPlayAgain()
    {
        if (_session is null || HasVotedRematch) return;
        _session.ProposeRematch(_playerName);
    }

    // ─── Result statistics helpers ────────────────────────────────────────────

    /// <summary>Total shots fired by the named player.</summary>
    private int GetShotCount(string playerName) =>
        _session?.ShotHistory.Count(s => s.ShooterName == playerName) ?? 0;

    /// <summary>Total hits (hit + sunk results) by the named player.</summary>
    private int GetHitCount(string playerName) =>
        _session?.ShotHistory.Count(s => s.ShooterName == playerName && s.Result != ShotResult.Miss) ?? 0;

    /// <summary>Accuracy percentage for the named player, formatted as "N%".</summary>
    private string GetAccuracy(string playerName)
    {
        var shots = GetShotCount(playerName);
        if (shots == 0) return "–";
        var hits = GetHitCount(playerName);
        return $"{(int)Math.Round((double)hits / shots * 100)}%";
    }

    /// <summary>Number of opponent ships sunk by the named player.</summary>
    private int GetShipsSunkCount(string playerName)
    {
        if (_session is null) return 0;
        var opponentBoard = _session.GetOpponentBoard(playerName);
        return opponentBoard?.Ships.Count(s => s.IsSunk) ?? 0;
    }

    // ─── Dispose ──────────────────────────────────────────────────────────────

    public void Dispose()
    {
        if (_session is not null)
            _session.StateChanged -= OnSessionStateChanged;
        _toastTimer?.Dispose();
    }
}
